# ============================================================
# DISSERTATION ML SCRIPT: STRESS-MOVE CLASSIFICATION
# 5-DAY HORIZON — RECALL-FOCUSED WITH RESTRICTED XGBOOST TUNING
# ============================================================
# Purpose:
# Predict whether freight rates experience an unusually large
# 5-day repricing episode ("stress move").
#
# Binary target:
#   1 = absolute h-day forward freight return exceeds stress threshold
#   0 = otherwise
#
# Core design:
#   - expanding-window forecasting
#   - stress threshold estimated only from initial training sample
#   - XGBoost eta and nrounds selected using initial training sample only
#   - recall-first probability cutoff selection on each expanding training window
#   - positive-class weighting to penalise missed stress events
#   - all features restricted to information observable at time t
#
# Important:
#   This script assumes that the daily ML master dataset `df` already exists
#   in the R environment.
# ============================================================


# ============================================================
# 0. LIBRARIES
# ============================================================

library(tidyverse)
library(lubridate)
library(zoo)
library(slider)
library(glmnet)
library(xgboost)
library(fastDummies)
library(pROC)


# ============================================================
# 1. SETTINGS
# ============================================================

forecast_horizon <- 5
initial_train <- 500
set.seed(123)

# Stress-event definition:
# 0.75 means top 25% of absolute h-day returns in the initial training sample.
stress_quantile <- 0.75

# Recall-focused classification rule.
threshold_objective <- "recall_with_precision_floor"
min_precision_floor <- 0.50
candidate_cutoffs <- seq(0.10, 0.70, by = 0.01)

# Class weighting.
positive_weight_multiplier_enet <- 1.50
positive_weight_multiplier_xgb  <- 1.25

# XGBoost complexity parameters fixed for parsimony.
# Only eta and nrounds are tuned below.
xgb_max_depth <- 3
xgb_min_child_weight <- 4
xgb_subsample <- 0.85
xgb_colsample_bytree <- 0.85

# Restricted tuning grid.
xgb_eta_grid <- c(0.02, 0.04, 0.05, 0.06, 0.08)
xgb_nrounds_grid <- c(75L, 100L, 150L, 250L, 350L)

# Output prefix.
output_prefix <- "stress_classification_5day_tuned"


# ============================================================
# 2. PREPARE BASE DATA
# ============================================================

if (!exists("df")) {
  stop("df is not available. Build the daily ML master dataset first.")
}

required_vars <- c(
  "date",
  "freight_rate",
  "daily_delay_rate",
  "daily_active_ships",
  "daily_port_arrivals",
  "daily_avg_turnaround_hours",
  "weather_stress_index",
  "joint_storm_dummy",
  "crude_oil_price",
  "trade_war",
  "tariff_rate",
  "goods_tariffed_pct"
)

missing_vars <- setdiff(required_vars, names(df))
if (length(missing_vars) > 0) {
  stop(paste("Missing required variables in df:", paste(missing_vars, collapse = ", ")))
}

base_df <- df %>%
  mutate(
    date = as.Date(date),
    crude_oil_price = zoo::na.locf(crude_oil_price, na.rm = FALSE),
    log_freight = log(freight_rate),
    d_log_freight = log_freight - lag(log_freight)
  ) %>%
  arrange(date)


# ============================================================
# 3. INITIAL THRESHOLDS FROM INITIAL TRAINING SAMPLE ONLY
# ============================================================

threshold_ref <- base_df %>%
  filter(!is.na(d_log_freight)) %>%
  slice(1:initial_train)

delay_p90    <- quantile(threshold_ref$daily_delay_rate, 0.90, na.rm = TRUE)
weather_p90  <- quantile(threshold_ref$weather_stress_index, 0.90, na.rm = TRUE)
arrivals_p10 <- quantile(threshold_ref$daily_port_arrivals, 0.10, na.rm = TRUE)

threshold_ref <- threshold_ref %>%
  mutate(d_log_oil_ref = log(crude_oil_price) - log(lag(crude_oil_price)))

oil_abs_p90 <- quantile(abs(threshold_ref$d_log_oil_ref), 0.90, na.rm = TRUE)

threshold_ref_h <- base_df %>%
  arrange(date) %>%
  mutate(h_forward_return_ref = lead(log_freight, forecast_horizon) - log_freight) %>%
  filter(!is.na(h_forward_return_ref)) %>%
  slice(1:initial_train)

stress_threshold <- quantile(
  abs(threshold_ref_h$h_forward_return_ref),
  stress_quantile,
  na.rm = TRUE
)

cat("------------------------------------------------------------\n")
cat("Forecast horizon =", forecast_horizon, "days\n")
cat("Stress threshold quantile =", stress_quantile, "\n")
cat("Stress threshold =", round(stress_threshold, 6), "\n")
cat("Threshold objective =", threshold_objective, "\n")
cat("Minimum precision floor =", min_precision_floor, "\n")
cat("------------------------------------------------------------\n")


# ============================================================

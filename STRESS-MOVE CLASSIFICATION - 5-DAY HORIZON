}


# ============================================================
# 6. HELPER FUNCTIONS
# ============================================================

safe_divide <- function(num, den) {
  ifelse(den == 0, NA_real_, num / den)
}

metric_bundle <- function(actual, pred_class, pred_prob) {
  actual <- as.integer(actual)
  pred_class <- as.integer(pred_class)
  pred_prob <- as.numeric(pred_prob)

  tp <- sum(actual == 1 & pred_class == 1, na.rm = TRUE)
  tn <- sum(actual == 0 & pred_class == 0, na.rm = TRUE)
  fp <- sum(actual == 0 & pred_class == 1, na.rm = TRUE)
  fn <- sum(actual == 1 & pred_class == 0, na.rm = TRUE)

  accuracy <- mean(actual == pred_class, na.rm = TRUE)
  precision <- safe_divide(tp, tp + fp)
  recall <- safe_divide(tp, tp + fn)
  specificity <- safe_divide(tn, tn + fp)

  f1 <- ifelse(
    is.na(precision) | is.na(recall) | (precision + recall == 0),
    NA_real_,
    2 * precision * recall / (precision + recall)
  )

  f2 <- ifelse(
    is.na(precision) | is.na(recall) | ((4 * precision + recall) == 0),
    NA_real_,
    5 * precision * recall / (4 * precision + recall)
  )

  balanced_accuracy <- mean(c(recall, specificity), na.rm = TRUE)

  auc_val <- tryCatch(
    as.numeric(pROC::roc(response = actual, predictor = pred_prob, quiet = TRUE)$auc),
    error = function(e) NA_real_
  )

  tibble::tibble(
    Accuracy = accuracy,
    Balanced_Accuracy = balanced_accuracy,
    Precision = precision,
    Recall = recall,
    Specificity = specificity,
    F1 = f1,
    F2 = f2,
    ROC_AUC = auc_val
  )
}

choose_best_cutoff <- function(actual,
                               probs,
                               cutoffs,
                               objective = "recall_with_precision_floor",
                               min_precision = 0.50) {
  actual <- as.integer(actual)
  probs <- as.numeric(probs)

  eval_tbl <- purrr::map_dfr(cutoffs, function(cut) {
    pred <- ifelse(probs >= cut, 1L, 0L)
    m <- metric_bundle(actual, pred, probs)

    tibble::tibble(
      cutoff = cut,
      Precision = m$Precision,
      Recall = m$Recall,
      F1 = m$F1,
      F2 = m$F2,
      Balanced_Accuracy = m$Balanced_Accuracy
    )
  })

  if (objective == "recall_with_precision_floor") {
    eligible <- eval_tbl %>%
      filter(!is.na(Precision), !is.na(Recall), Precision >= min_precision)

    if (nrow(eligible) > 0) {
      return(
        eligible %>%
          arrange(desc(Recall), desc(F1), desc(Balanced_Accuracy), cutoff) %>%
          slice(1) %>%
          pull(cutoff)
      )
    }

    # Fallback if no cutoff reaches the floor.
    return(
      eval_tbl %>%
        filter(!is.na(F1)) %>%
        arrange(desc(F1), desc(Balanced_Accuracy), desc(Recall), cutoff) %>%
        slice(1) %>%
        pull(cutoff)
    )
  }

  if (objective == "pure_recall") {
    return(
      eval_tbl %>%
        filter(!is.na(Recall)) %>%
        arrange(desc(Recall), desc(F1), cutoff) %>%
        slice(1) %>%
        pull(cutoff)
    )
  }

  if (objective == "balanced_accuracy") {
    return(
      eval_tbl %>%
        filter(!is.na(Balanced_Accuracy)) %>%
        arrange(desc(Balanced_Accuracy), desc(Recall), cutoff) %>%
        slice(1) %>%
        pull(cutoff)
    )
  }

  if (objective == "f2") {
    return(
      eval_tbl %>%
        filter(!is.na(F2)) %>%
        arrange(desc(F2), desc(F1), desc(Recall), cutoff) %>%
        slice(1) %>%
        pull(cutoff)
    )
  }

  eval_tbl %>%
    filter(!is.na(F1)) %>%
    arrange(desc(F1), desc(Recall), cutoff) %>%
    slice(1) %>%
    pull(cutoff)
}

confusion_summary <- function(actual, pred_class, model_name) {
  tibble::tibble(
    Model = model_name,
    TP = sum(actual == 1 & pred_class == 1, na.rm = TRUE),
    TN = sum(actual == 0 & pred_class == 0, na.rm = TRUE),
    FP = sum(actual == 0 & pred_class == 1, na.rm = TRUE),
    FN = sum(actual == 1 & pred_class == 0, na.rm = TRUE)
  )
}


# ============================================================
# 6A. RESTRICTED XGBOOST HYPERPARAMETER TUNING
# Select eta and nrounds using initial training sample only
# ============================================================

set.seed(123)

tune_data <- model_df[1:initial_train, , drop = FALSE]

# Chronological inner validation split.
tune_valid_n <- floor(0.20 * nrow(tune_data))
tune_train_n <- nrow(tune_data) - tune_valid_n

tune_train <- tune_data[1:tune_train_n, , drop = FALSE]
tune_valid <- tune_data[(tune_train_n + 1):nrow(tune_data), , drop = FALSE]

x_tune_train <- as.matrix(tune_train[, feature_vars, drop = FALSE])
y_tune_train <- as.integer(tune_train[[target_var]])

x_tune_valid <- as.matrix(tune_valid[, feature_vars, drop = FALSE])
y_tune_valid <- as.integer(tune_valid[[target_var]])

pos_count_tune <- sum(y_tune_train == 1, na.rm = TRUE)
neg_count_tune <- sum(y_tune_train == 0, na.rm = TRUE)

scale_pos_weight_tune <- positive_weight_multiplier_xgb *
  (neg_count_tune / max(pos_count_tune, 1))

d_tune_train <- xgboost::xgb.DMatrix(
  data = x_tune_train,
  label = y_tune_train
)

d_tune_valid <- xgboost::xgb.DMatrix(
  data = x_tune_valid,
  label = y_tune_valid
)

xgb_grid <- tidyr::crossing(
  eta = xgb_eta_grid,
  nrounds = xgb_nrounds_grid
)

xgb_tuning_results <- purrr::map_dfr(seq_len(nrow(xgb_grid)), function(g) {

  eta_g <- xgb_grid$eta[g]
  nrounds_g <- as.integer(xgb_grid$nrounds[g])

  fit_g <- xgboost::xgb.train(
    params = list(
      objective = "binary:logistic",
      eval_metric = "logloss",
      max_depth = xgb_max_depth,
      eta = eta_g,
      min_child_weight = xgb_min_child_weight,
      subsample = xgb_subsample,
      colsample_bytree = xgb_colsample_bytree,
      scale_pos_weight = scale_pos_weight_tune,
      verbosity = 0
    ),
    data = d_tune_train,
    nrounds = nrounds_g
  )

  train_prob_g <- as.numeric(predict(fit_g, newdata = d_tune_train))
  valid_prob_g <- as.numeric(predict(fit_g, newdata = d_tune_valid))

  cutoff_g <- choose_best_cutoff(
    actual = y_tune_train,
    probs = train_prob_g,
    cutoffs = candidate_cutoffs,
    objective = threshold_objective,
    min_precision = min_precision_floor
  )

  valid_pred_g <- ifelse(valid_prob_g >= cutoff_g, 1L, 0L)

  m_valid <- metric_bundle(
    actual = y_tune_valid,
    pred_class = valid_pred_g,
    pred_prob = valid_prob_g
  )

  tibble::tibble(
    horizon = forecast_horizon,
    eta = eta_g,
    nrounds = nrounds_g,
    selected_cutoff = cutoff_g,
    validation_Accuracy = m_valid$Accuracy,
    validation_Balanced_Accuracy = m_valid$Balanced_Accuracy,
    validation_Precision = m_valid$Precision,
    validation_Recall = m_valid$Recall,
    validation_Specificity = m_valid$Specificity,
    validation_F1 = m_valid$F1,
    validation_F2 = m_valid$F2,
    validation_ROC_AUC = m_valid$ROC_AUC
  )
})

xgb_tuning_feasible <- xgb_tuning_results %>%
  filter(!is.na(validation_Precision), validation_Precision >= min_precision_floor)

if (nrow(xgb_tuning_feasible) > 0) {
  best_xgb_params <- xgb_tuning_feasible %>%
    arrange(
      desc(validation_Recall),
      desc(validation_F1),
      desc(validation_ROC_AUC),
      desc(validation_Balanced_Accuracy)
    ) %>%
    slice(1)
} else {
  best_xgb_params <- xgb_tuning_results %>%
    arrange(
      desc(validation_F1),
      desc(validation_ROC_AUC),
      desc(validation_Balanced_Accuracy),
      desc(validation_Recall)
    ) %>%
    slice(1)
}

selected_xgb_eta <- best_xgb_params$eta
selected_xgb_nrounds <- as.integer(best_xgb_params$nrounds)

cat("Selected XGBoost classification parameters for", forecast_horizon, "day horizon:\n")
cat("eta =", selected_xgb_eta, "\n")
cat("nrounds =", selected_xgb_nrounds, "\n")

readr::write_csv(
  xgb_tuning_results,
  paste0("xgb_classification_tuning_", forecast_horizon, "day.csv")
)

readr::write_csv(
  best_xgb_params,
  paste0("xgb_classification_best_params_", forecast_horizon, "day.csv")
)


# ============================================================
# 7. RESULTS OBJECT
# ============================================================

results <- tibble::tibble(
  date = model_df$date[(initial_train + 1):n],
  actual = model_df[[target_var]][(initial_train + 1):n],

  prob_majority = NA_real_,
  pred_majority = NA_integer_,

  prob_persistence = NA_real_,
  pred_persistence = NA_integer_,

  prob_enet = NA_real_,
  pred_enet = NA_integer_,
  cutoff_enet = NA_real_,

  prob_xgb = NA_real_,
  pred_xgb = NA_integer_,
  cutoff_xgb = NA_real_
)


# ============================================================
# 8. EXPANDING-WINDOW FORECAST LOOP
# ============================================================

for (i in (initial_train + 1):n) {

  train_data <- model_df[1:(i - 1), , drop = FALSE]
  test_data  <- model_df[i, , drop = FALSE]
  j <- i - initial_train

  x_train <- as.matrix(train_data[, feature_vars, drop = FALSE])
  y_train <- as.integer(train_data[[target_var]])
  x_test  <- as.matrix(test_data[, feature_vars, drop = FALSE])

  pos_count <- sum(y_train == 1, na.rm = TRUE)
  neg_count <- sum(y_train == 0, na.rm = TRUE)
  base_pos_weight <- neg_count / max(pos_count, 1)

  # ----------------------------------------------------------
  # Benchmark 1: Majority benchmark
  # ----------------------------------------------------------
  train_pos_rate <- mean(y_train, na.rm = TRUE)
  majority_class <- ifelse(train_pos_rate >= 0.5, 1L, 0L)

  results$prob_majority[j] <- train_pos_rate
  results$pred_majority[j] <- majority_class

  # ----------------------------------------------------------
  # Benchmark 2: past-horizon persistence benchmark
  # ----------------------------------------------------------
  persistence_prob <- as.numeric(test_data$current_past_stress)
  persistence_prob <- ifelse(is.na(persistence_prob), 0, persistence_prob)
  persistence_class <- ifelse(persistence_prob >= 0.5, 1L, 0L)

  results$prob_persistence[j] <- persistence_prob
  results$pred_persistence[j] <- persistence_class

  # ----------------------------------------------------------
  # Elastic Net logistic regression
  # ----------------------------------------------------------
  obs_weights <- ifelse(
    y_train == 1,
    base_pos_weight * positive_weight_multiplier_enet,
    1
  )

  enet_fit <- glmnet::cv.glmnet(
    x = x_train,
    y = y_train,
    family = "binomial",
    alpha = 0.5,
    nfolds = 5,
    weights = obs_weights,
    type.measure = "deviance"
  )

  enet_train_prob <- as.numeric(
    predict(enet_fit, newx = x_train, s = "lambda.min", type = "response")
  )

  best_cut_enet <- choose_best_cutoff(
    actual = y_train,
    probs = enet_train_prob,
    cutoffs = candidate_cutoffs,
    objective = threshold_objective,
    min_precision = min_precision_floor
  )

  enet_test_prob <- as.numeric(
    predict(enet_fit, newx = x_test, s = "lambda.min", type = "response")
  )

  enet_test_class <- ifelse(enet_test_prob >= best_cut_enet, 1L, 0L)

  results$prob_enet[j] <- enet_test_prob
  results$pred_enet[j] <- enet_test_class
  results$cutoff_enet[j] <- best_cut_enet

  # ----------------------------------------------------------
  # XGBoost classifier using restricted tuned parameters
  # ----------------------------------------------------------
  xgb_scale_pos_weight <- base_pos_weight * positive_weight_multiplier_xgb

  dtrain <- xgboost::xgb.DMatrix(
    data = x_train,
    label = y_train
  )

  dtest <- xgboost::xgb.DMatrix(
    data = x_test
  )

  xgb_fit <- xgboost::xgb.train(
    params = list(
      objective = "binary:logistic",
      eval_metric = "logloss",
      max_depth = xgb_max_depth,
      eta = selected_xgb_eta,
      min_child_weight = xgb_min_child_weight,
      subsample = xgb_subsample,
      colsample_bytree = xgb_colsample_bytree,
      scale_pos_weight = xgb_scale_pos_weight,
      verbosity = 0
    ),
    data = dtrain,
    nrounds = selected_xgb_nrounds
  )

  xgb_train_prob <- as.numeric(predict(xgb_fit, newdata = dtrain))

  best_cut_xgb <- choose_best_cutoff(
    actual = y_train,
    probs = xgb_train_prob,
    cutoffs = candidate_cutoffs,
    objective = threshold_objective,
    min_precision = min_precision_floor
  )

  xgb_test_prob <- as.numeric(predict(xgb_fit, newdata = dtest))
  xgb_test_class <- ifelse(xgb_test_prob >= best_cut_xgb, 1L, 0L)

  results$prob_xgb[j] <- xgb_test_prob
  results$pred_xgb[j] <- xgb_test_class
  results$cutoff_xgb[j] <- best_cut_xgb

  if (j %% 25 == 0) {
    cat("Completed forecast", j, "of", n - initial_train, "\n")
  }
}



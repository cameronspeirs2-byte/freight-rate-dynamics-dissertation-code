# ============================================================
# 22. SIMPLE FORECAST COMPARISON
# Compare:
# - zero-change naive
# - ARIMA
# - final dynamic regression
# Forecast target: d_log_freight
# Holdout: final 6 months
# ============================================================

forecast_data <- final_data %>%
  arrange(month)

train_data <- forecast_data %>% slice(1:(n() - 6))
test_data  <- forecast_data %>% slice((n() - 5):n())

# ----------------------------
# 22.1 Naive benchmark: forecast zero monthly change
# ----------------------------
naive_forecast <- rep(0, nrow(test_data))

# ----------------------------
# 22.2 ARIMA forecast
# ----------------------------
train_ts <- ts(train_data$d_log_freight, frequency = 12, start = c(2017, 3))
arima_train <- auto.arima(
  train_ts,
  seasonal = FALSE,
  stepwise = FALSE,
  approximation = FALSE
)

arima_fc <- forecast(arima_train, h = nrow(test_data))
arima_forecast <- as.numeric(arima_fc$mean)

# ----------------------------
# 22.3 Dynamic regression forecast
# One-step-ahead recursive forecast
# ----------------------------
dynamic_forecasts <- c()

rolling_data <- train_data

for (i in 1:nrow(test_data)) {
  model_i <- lm(
    d_log_freight ~ lag_d_log_freight +
      daily_delay_rate +
      weather_stress_index +
      trade_war +
      d_log_industrial +
      d_log_oil,
    data = rolling_data
  )
  
  next_obs <- test_data[i, ]
  
  pred_i <- predict(model_i, newdata = next_obs)
  dynamic_forecasts <- c(dynamic_forecasts, pred_i)
  
  rolling_data <- bind_rows(rolling_data, next_obs)
}

# ----------------------------
# 22.4 Accuracy comparison
# ----------------------------
actual <- test_data$d_log_freight

rmse <- function(a, f) sqrt(mean((a - f)^2, na.rm = TRUE))
mae  <- function(a, f) mean(abs(a - f), na.rm = TRUE)
mape <- function(a, f) mean(abs((a - f) / a), na.rm = TRUE) * 100

forecast_comparison <- tibble(
  model = c("Naive_Zero_Change", "ARIMA", "Dynamic_Regression"),
  RMSE = c(
    rmse(actual, naive_forecast),
    rmse(actual, arima_forecast),
    rmse(actual, dynamic_forecasts)
  ),
  MAE = c(
    mae(actual, naive_forecast),
    mae(actual, arima_forecast),
    mae(actual, dynamic_forecasts)
  ),
  MAPE = c(
    mape(actual, naive_forecast),
    mape(actual, arima_forecast),
    mape(actual, dynamic_forecasts)
  )
) %>%
  arrange(RMSE)

forecast_comparison
write_csv(forecast_comparison, "forecast_comparison.csv")

forecast_results_tbl <- tibble(
  month = test_data$month,
  actual_d_log_freight = actual,
  naive_zero_change = naive_forecast,
  arima_forecast = arima_forecast,
  dynamic_regression_forecast = dynamic_forecasts
)

forecast_results_tbl
write_csv(forecast_results_tbl, "forecast_results_monthly.csv")

ggplot(forecast_results_tbl, aes(x = month)) +
  geom_line(aes(y = actual_d_log_freight, colour = "Actual")) +
  geom_line(aes(y = naive_zero_change, colour = "Naive")) +
  geom_line(aes(y = arima_forecast, colour = "ARIMA")) +
  geom_line(aes(y = dynamic_regression_forecast, colour = "Dynamic Regression")) +
  theme_minimal() +
  labs(
    title = "Forecast Comparison: Monthly Freight Growth",
    x = "Month",
    y = "d_log_freight",
    colour = NULL
  )


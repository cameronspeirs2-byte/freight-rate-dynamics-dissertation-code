# ============================================================
# 1. GLOBAL SETTINGS
# ============================================================

start_date <- as.Date("2017-01-01")
end_date   <- as.Date("2019-12-31")

# ============================================================
# 2. HELPER FUNCTIONS
# ============================================================

safe_numeric <- function(x) {
  as.numeric(gsub(",", "", x))
}

run_stationarity_tests <- function(series, series_name) {
  x <- na.omit(series)
  tibble(
    variable = series_name,
    adf_p_value = tryCatch(adf.test(x)$p.value, error = function(e) NA_real_),
    kpss_p_value = tryCatch(kpss.test(x)$p.value, error = function(e) NA_real_)
  )
}

nw_coeftest <- function(model, lag = 3) {
  coeftest(model, vcov = NeweyWest(model, lag = lag, prewhite = FALSE))
}

extract_model_stats <- function(fitted_model, model_name) {
  model_summary <- summary(fitted_model)
  
  tibble(
    model = model_name,
    r2 = model_summary$r.squared,
    adj_r2 = model_summary$adj.r.squared,
    aic = AIC(fitted_model),
    bic = BIC(fitted_model),
    n = length(residuals(fitted_model))
  )
}

# ============================================================
# 3. IMPORT RAW DATA
# ============================================================

freight    <- read_csv("freight_daily.csv", show_col_types = FALSE)
ais        <- read_csv("daily_data.csv", show_col_types = FALSE)
weather    <- read_csv("weather_daily_route.csv", show_col_types = FALSE)
pmi        <- read_csv("PMI.csv", show_col_types = FALSE)
industrial <- read_csv("Industrial Production.csv", show_col_types = FALSE)
exchange   <- read_csv("DTWEXBGS.csv", show_col_types = FALSE)

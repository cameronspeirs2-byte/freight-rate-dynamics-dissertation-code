  mutate(month = floor_date(date, "month")) %>%
  group_by(month) %>%
  summarise(
    across(where(is.numeric), ~ mean(.x, na.rm = TRUE)),
    .groups = "drop"
  )

# ----------------------------
# 5.3 Weather monthly
# ----------------------------
weather_monthly <- weather %>%
  mutate(month = floor_date(date, "month")) %>%
  group_by(month) %>%
  summarise(
    across(where(is.numeric), ~ mean(.x, na.rm = TRUE)),
    .groups = "drop"
  )

# ----------------------------
# 5.4 Oil monthly
# ----------------------------
oil_monthly <- oil %>%
  mutate(month = floor_date(date, "month")) %>%
  group_by(month) %>%
  summarise(
    crude_oil_price = mean(crude_oil_price, na.rm = TRUE),

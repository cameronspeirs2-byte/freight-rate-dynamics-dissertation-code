# 17b. BOOTSTRAP INFERENCE ROBUSTNESS

set.seed(123)

n_boot <- 2000

X_baseline <- model.matrix(final_baseline)
fitted_baseline <- fitted(final_baseline)
resid_baseline <- residuals(final_baseline)

boot_coef_mat <- matrix(
  NA_real_,
  nrow = n_boot,
  ncol = ncol(X_baseline)
)

colnames(boot_coef_mat) <- colnames(X_baseline)

for (b in 1:n_boot) {
  boot_resid <- sample(resid_baseline, size = length(resid_baseline), replace = TRUE)
  y_boot <- fitted_baseline + boot_resid
  
  boot_data <- final_data
  boot_data$d_log_freight <- y_boot
  
  boot_model <- lm(
    d_log_freight ~ lag_d_log_freight +
      daily_delay_rate +
      weather_stress_index +
      trade_war +
      d_log_industrial +
      d_log_oil,
    data = boot_data
  )
  
  boot_coef_mat[b, ] <- coef(boot_model)
}

bootstrap_se <- apply(boot_coef_mat, 2, sd, na.rm = TRUE)

baseline_coef <- coef(final_baseline)
bootstrap_t <- baseline_coef / bootstrap_se
bootstrap_p <- 2 * (1 - pnorm(abs(bootstrap_t)))

bootstrap_ci <- t(apply(boot_coef_mat, 2, quantile, probs = c(0.025, 0.975), na.rm = TRUE))

bootstrap_results <- tibble(
  term = names(baseline_coef),
  estimate = as.numeric(baseline_coef),
  bootstrap_std_error = as.numeric(bootstrap_se),
  bootstrap_t_stat = as.numeric(bootstrap_t),
  bootstrap_p_value = as.numeric(bootstrap_p),
  ci_lower_95 = bootstrap_ci[, 1],
  ci_upper_95 = bootstrap_ci[, 2]
)

bootstrap_results
write_csv(bootstrap_results, "baseline_bootstrap_results.csv")

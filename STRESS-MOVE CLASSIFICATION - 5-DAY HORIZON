target_var <- "target_stress_move"

# Exclude direct target variables and the raw forward return.
# past_h_return is excluded because it is continuous and mechanically aligned
# with the persistence benchmark. The binary current_past_stress remains as
# an observable feature.
feature_vars <- setdiff(
  names(model_df),
  c("date", target_var, "target_h_return", "past_h_return")
)


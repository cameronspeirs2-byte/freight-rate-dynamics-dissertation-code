# ============================================================
# 4. CLEAN AND STANDARDISE DATASETS
# ============================================================

# ----------------------------
# 4.1 Freight
# ----------------------------
freight <- freight %>%
  mutate(date = as_date(Date)) %>%
  transmute(
    date,
    freight_rate = safe_numeric(XSICFEUW)
  ) %>%
  filter(date >= start_date, date <= end_date)

# ----------------------------
# 4.2 AIS
# ----------------------------
ais <- ais %>%
  mutate(date = as_date(date)) %>%
  filter(date >= start_date, date <= end_date)

# ----------------------------
# 4.3 Weather
# ----------------------------
weather <- weather %>%
  mutate(date = as_date(date)) %>%
  filter(date >= start_date, date <= end_date)

# ----------------------------
# 4.4 PMI
# ----------------------------
pmi <- pmi %>%
  filter(...3 != "Date") %>%
  transmute(
    date = my(...3),
    pmi = safe_numeric(...4)
  ) %>%
  filter(date >= start_date, date <= end_date)

# ----------------------------
# 4.5 Industrial production
# ----------------------------
industrial <- industrial %>%
  transmute(
    date = ym(date),
    industrial_production = safe_numeric(industrial_production)
  ) %>%
  filter(date >= start_date, date <= end_date)

# ----------------------------
# 4.6 USD index
# ----------------------------
exchange <- exchange %>%
  transmute(
    date = as_date(observation_date),
    usd_index = safe_numeric(DTWEXBGS)
  ) %>%
  filter(date >= start_date, date <= end_date)

# ----------------------------
# 4.7 Tariff data
# ----------------------------
tariff <- tariff %>%
  mutate(date = as_date(date)) %>%
  arrange(date) %>%
  mutate(
    trade_war = if_else(tariff_rate > 0, 1, 0)
  ) %>%
  filter(date >= start_date, date <= end_date)

# ----------------------------
# 4.8 Crude oil price
# ----------------------------
oil <- oil_raw %>%
  transmute(
    date = as_date(observation_date),
    crude_oil_price = safe_numeric(DCOILBRENTEU)
  ) %>%
  filter(date >= start_date, date <= end_date) %>%
  arrange(date)

# ============================================================
# 5. CONVERT TO MONTHLY DATA
# ============================================================


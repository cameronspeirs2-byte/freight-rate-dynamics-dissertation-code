  left_join(ais_monthly, by = "month") %>%
  left_join(weather_monthly, by = "month") %>%
  left_join(pmi_monthly, by = "month") %>%
  left_join(industrial_monthly, by = "month") %>%
  left_join(exchange_monthly, by = "month") %>%
  left_join(tariff_monthly, by = "month") %>%
  left_join(oil_monthly, by = "month") %>%
  arrange(month)

